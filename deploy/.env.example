# Library deploy environment. Copy to `.env` (gitignored). Compose reads it automatically.

# Host path to the music you want to serve, mounted at /data/music (read-write; see compose.prod.yaml).
MUSIC_DIR=/srv/music

# ── Only needed for the optional edge-TLS overlay (compose.edge.yaml) ───────────────────────────
LIBRARY_DOMAIN=library.example.com
CERTBOT_EMAIL=you@example.com
# Set to 1 to use the Let's Encrypt staging CA while testing (avoids rate limits); 0 for real certs.
CERTBOT_STAGING=0
